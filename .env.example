# ---------------------------------------------------------------------------
# Environment variables
#
# The site currently runs with ZERO required environment variables — all
# content lives in src/content/*.ts and src/content/blog/*.mdx, and the
# site is fully static. This file documents the variables you'll likely
# add as the site grows, so the structure is ready when you need it.
# ---------------------------------------------------------------------------

# --- Site URL (used in metadata, sitemap, OG tags) --------------------------
# Update src/app/layout.tsx and src/app/sitemap.ts directly, or wire these
# constants to read from this variable if you prefer environment-driven config.
NEXT_PUBLIC_SITE_URL=https://ifiokcolumba.dev

# --- Contact form (if you add one later) -------------------------------------
# Example using Resend (https://resend.com) for a serverless contact form API route.
# RESEND_API_KEY=
# CONTACT_EMAIL_TO=hello@ifiokcolumba.dev

# --- Analytics (optional) ----------------------------------------------------
# Example: Vercel Analytics is zero-config if you install @vercel/analytics.
# Example: Plausible / Umami self-hosted analytics script URL.
# NEXT_PUBLIC_ANALYTICS_ID=

# --- Headless CMS (optional future upgrade) ----------------------------------
# If you outgrow the local TypeScript content files in src/content/, these
# are common variables for a headless CMS migration (e.g. Sanity, Contentful):
# NEXT_PUBLIC_CMS_PROJECT_ID=
# CMS_API_TOKEN=
